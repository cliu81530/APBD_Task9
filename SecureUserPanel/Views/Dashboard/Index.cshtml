@model IEnumerable<UserNote>
@{ ViewData["Title"] = "Dashboard"; }

<h1>My Dashboard</h1>
<p><a asp-action="AddNote">+ Add Note</a></p>

@if (!Model.Any())
{
    <p>No notes yet.</p>
}
else
{
    <table>
        <thead>
            <tr><th>Title</th><th>Content</th><th>Created</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var note in Model)
        {
            <tr>
                <td>@note.Title</td>
                <td>@note.Content</td>
                <td>@note.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <form method="post" asp-action="DeleteNote" asp-route-id="@note.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" onclick="return confirm('Delete this note?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}