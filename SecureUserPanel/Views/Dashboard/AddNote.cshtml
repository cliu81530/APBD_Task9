@model NoteViewModel
@{ ViewData["Title"] = "Add Note"; }

<h1>Add Note</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="error"></div>

    <label asp-for="Title">Title</label>
    <input asp-for="Title" type="text" />
    <span asp-validation-for="Title" class="field-validation-error"></span>

    <label asp-for="Content">Content</label>
    <textarea asp-for="Content" rows="5" style="max-width:400px;width:100%"></textarea>
    <span asp-validation-for="Content" class="field-validation-error"></span>

    <button type="submit">Save</button>
    <a asp-action="Index" style="margin-left:1rem">Cancel</a>
</form>