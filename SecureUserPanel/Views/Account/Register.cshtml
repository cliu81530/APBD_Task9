@model RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<h1>Create Account</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="error"></div>

    <label asp-for="Email">Email</label>
    <input asp-for="Email" type="email" />
    <span asp-validation-for="Email" class="field-validation-error"></span>

    <label asp-for="Password">Password</label>
    <input asp-for="Password" type="password" />
    <span asp-validation-for="Password" class="field-validation-error"></span>

    <label asp-for="ConfirmPassword">Confirm Password</label>
    <input asp-for="ConfirmPassword" type="password" />
    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>

    <button type="submit">Register</button>
</form>

<p style="margin-top:1rem">Already have an account? <a asp-controller="Account" asp-action="Login">Login</a></p>