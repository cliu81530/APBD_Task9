<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – UserPanel</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
        nav { display: flex; gap: 1rem; margin-bottom: 2rem; border-bottom: 1px solid #ccc; padding-bottom: 0.5rem; }
        nav a { text-decoration: none; color: #0066cc; }
        .error { color: red; }
        .field-validation-error { color: red; font-size: 0.85em; }
        input[type=text], input[type=email], input[type=password], textarea {
            display: block; width: 100%; max-width: 400px;
            padding: 0.4rem; margin-bottom: 0.75rem; box-sizing: border-box;
        }
        button, .btn { padding: 0.4rem 1rem; cursor: pointer; }
        table { border-collapse: collapse; width: 100%; }
        td, th { border: 1px solid #ccc; padding: 0.5rem; text-align: left; }
    </style>
</head>
<body>
    <nav>
        <strong>UserPanel</strong>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/Dashboard">Dashboard</a>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin">Admin</a>
            }
            <form method="post" action="/Account/Logout" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" style="background:none;border:none;color:#0066cc;cursor:pointer;padding:0">Logout</button>
            </form>
            <span style="margin-left:auto;color:#555">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
        }
        else
        {
            <a href="/Account/Login">Login</a>
            <a href="/Account/Register">Register</a>
        }
    </nav>

    @RenderBody()
</body>
</html>